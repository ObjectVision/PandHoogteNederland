container AHN4
{
// bij nieuwe AHN of toevoegingen aan AHN, maak eerst bestand: %AHNDrive%/AHN4/dir_list.txt opnieuw aan met commando: dir /S /B > dir_list.txt in de %AHNDrive%/AHN4_cm folder

	parameter<string> AHN_version:= 'AHN_4';

	unit<uint32> blad_alle:
		StorageName     = "='%AHNDrive%/ahn_units.shp'"
	,	StorageType     = "gdal.vect"
	,	StorageReadOnly = "True"
	,	KeepData        = "True"
	{
		attribute<point_rd> geometry (poly);
		attribute<string>   unit;
		attribute<bool>     IsIncorrect10dz2 := id(.) == 1403;
		attribute<bool>     HeeftAHN4data    := isDefined(rlookup(lowercase(unit), lowercase(blad_files/with_data/values)));
		attribute<bool>     conditie         := HeeftAHN4data && !IsIncorrect10dz2;
	}

	parameter<string> blad_files:
		StorageName     = "='%AHNDrive%/' + AHN_version + '_cm/dir_list.txt'"
	,	StorageType     = "str"
	,	StorageReadOnly = "True"
	,	KeepData        = "True"
	{
		parameter<uint32> nr_rows := strcount(blad_files, '\n');
		unit<uint32> all := range(uint32,0,nr_rows)
		{
			parameter<string> Header         := ReadLines(blad_files, void, 0);
			attribute<string> BodyRows (all) := ReadLines(blad_files, all, Header/ReadPos);
		}
		unit<uint32> tiff := select_with_org_rel(strcount(all/BodyRows,'.tif') > 0)
		{
			attribute<string> pathname          := all/BodyRows[org_rel];
			attribute<uint32> startpos_filename := strrpos(pathname, '\\') + 1;
			attribute<string> filename          := substr(pathname, startpos_filename);
			attribute<string> bladname          := replace(filename, '.tif', '');
		}
		unit<uint32> blad_unique := unique(tiff/bladname)
		{
			attribute<uint32> count := pcount(rlookup(tiff/bladname, values));
		}
		unit<uint32> with_data := select_with_attr_by_cond(blad_unique, blad_unique/count == 2);
	}

	unit<uint32> blad := select_with_attr_by_cond(blad_alle, blad_alle/conditie) 
	{
		// attribute<ipoint>   geometry_ipol (poly) := ipolygon(geometry);
		attribute<string>   name                 := 'blad_' + unit;
		attribute<Geografie/blad_grid/domain> blad_grid_rel := centroid(geometry)[Geografie/blad_grid/domain];

		attribute<string> int_filename := expand(., '%AHNDrive%') + '/AHN_4_cm/DTM/' + unit + '.tif';
		attribute<string> ruw_filename := replace(int_filename, 'DTM', 'DSM');

		/*attribute<jaar>   inwinjaar         := rjoin(id(.), inwinjaren/intersect_AHN/first_rel, inwinjaren/intersect_AHN/inwinjaar_AHN);


		container inwinjaren
		{
			unit<uint32> intersect_AHN := overlay_polygon(ipolygon(blad/geometry), ipolygon(inwinjaren_AHN/geometry))
			{
				attribute<jaar> inwinjaar_AHN := inwinjaren_AHN/inwinjaar_AH4[second_rel];
			}
		}*/
	}

// container inwinjaren_AHN
