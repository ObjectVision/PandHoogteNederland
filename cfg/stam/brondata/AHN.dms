	unit<uint32> inwinjaren_AHN:
		StorageName = "%AHNDrive%/inwinjaren_AHN3_def.shp"
	,	StorageType = "gdal.vect"
	,	StorageReadOnly = "True"
	{
		attribute<point_rd>      geometry (poly);
		attribute<string>        jaar;      
		attribute<eenheden/jaar> inwinjaar_AH3   := jaar[eenheden/jaar];
		attribute<eenheden/jaar> inwinjaar_AH4   := switch( //bron:https://www.ahn.nl/ahn-4
														case(id(.) == V/ZuidHolland, 2020[eenheden/jaar])
														, case(id(.) == V/Friesland, 2020[eenheden/jaar])
														, case(id(.) == V/NoordHolland, 2020[eenheden/jaar])
														, case(id(.) == V/Brabant, 2021[eenheden/jaar])
														, case(id(.) == V/Flevoland, 2022[eenheden/jaar])
														, case(id(.) == V/Veluwe, 2022[eenheden/jaar])
														, case(id(.) == V/Rivieren, 2022[eenheden/jaar])
														, case(id(.) == V/Limburg, 2021[eenheden/jaar])
														, case(id(.) == V/Zeeland, 2020[eenheden/jaar])
														, case(id(.) == V/Gooi, 2020[eenheden/jaar])
														, case(id(.) == V/Groningen, 2020[eenheden/jaar])
														, (0/0)[eenheden/jaar]
													);
		attribute<string>       label          := switch(
														case(id(.) == 0, 'ZuidHolland')
														, case(id(.) == 1, 'Friesland')
														, case(id(.) == 2, 'NoordHolland')
														, case(id(.) == 3, 'Brabant')
														, case(id(.) == 4, 'Flevoland')
														, case(id(.) == 5, 'Veluwe')
														, case(id(.) == 6, 'Rivieren')
														, case(id(.) == 7, 'Limburg')
														, case(id(.) == 8, 'Zeeland')
														, case(id(.) == 9, 'Gooi')
														, case(id(.) == 10, 'Groningen')
														, ''
													);
													
		container V := for_each_nedv(lowercase(label), 'value('+string(id(.))+', ..)', void, .);
	}

	container BAG_perspectieven
	{
		unit<uint32> blad := unique(overlay_ahn_with_bag_data/second_rel), label = "unieke AHN bladen met BAG data"
		{
			attribute<string> name := brondata/AHN4/blad/name[values];
		}

		container per_blad := for_each_ne(
			 blad/name
			,'Schemas/ahn_set_to_BAG_perspectieven/bepaal_BAG_perspectief_griddomeinen_en_lees_data_per_blad(brondata/AHN4/blad,' + string(blad/values) + ')'
		);
	}
	
}